config_version=5

[application]

config/name="Nuevo Proyecto de Juego"
run/main_scene="res://scenes/menu_principal.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Estado="*res://scripts/game_state.gd"
ClaudeRuntime="*res://addons/claude_bridge/runtime_agent.gd"

[editor_plugins]

